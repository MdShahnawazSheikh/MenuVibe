<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      MenuVibe runs OUTSIDE the App Sandbox by design.

      The Window Snapper drives the Accessibility API (AXUIElement) to move and
      resize *other apps'* windows. The App Sandbox forbids that cross-process
      control outright, so a sandboxed build cannot ship the snapper at all. This is
      the one documented sandbox exception (spec §10), and it is why MenuVibe is
      distributed as a notarized, hardened-runtime app rather than via the Mac App
      Store. Everything else (clipboard, notes) stays entirely local to
      ~/Library/Application Support/MenuVibe.
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Hardened Runtime is still enabled at sign time for notarization. -->
    <key>com.apple.security.automation.apple-events</key>
    <false/>
</dict>
</plist>
